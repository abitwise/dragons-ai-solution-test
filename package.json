{
  "name": "dragons-of-mugloar-bot",
  "version": "0.1.0",
  "description": "A TypeScript CLI bot that autoplays Dragons of Mugloar via its public HTTP API.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write ."
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "~5.9",
    "vitest": "^4.1.8"
  }
}
